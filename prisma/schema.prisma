// CoreInventory - Prisma Schema
// Inventory Management System for Odoo Hackathon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH MODELS ====================

model User {
  id            String    @id @default(cuid())
  loginId       String    @unique @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts Account[]
  sessions Session[]

  // Inventory relations
  receipts       Receipt[]
  deliveryOrders DeliveryOrder[]
  transfers      InternalTransfer[]
  adjustments    StockAdjustment[]
  stockMoves     StockMove[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model token {
  id      String     @id @default(cuid())
  email   String
  token   String     @unique
  type    TokenTypes
  expires DateTime

  @@unique([email, token, type])
  @@index([email, type])
}

enum TokenTypes {
  EmailVerification
  PasswordReset
}

// ==================== WAREHOUSE & LOCATION ====================

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  shortCode String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]
}

model Location {
  id          String   @id @default(cuid())
  name        String
  shortCode   String
  warehouseId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  stockQuants      StockQuant[]
  movesFrom        StockMove[]        @relation("FromLocation")
  movesTo          StockMove[]        @relation("ToLocation")
  transfersFrom    InternalTransfer[] @relation("TransferFrom")
  transfersTo      InternalTransfer[] @relation("TransferTo")
  stockAdjustments StockAdjustment[]

  @@unique([shortCode, warehouseId])
}

// ==================== PRODUCT ====================

model ProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  categoryId    String?
  unitOfMeasure String   @default("Units")
  costPerUnit   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category        ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reorderRule     ReorderRule?
  stockQuants     StockQuant[]
  receiptLines    ReceiptLine[]
  deliveryLines   DeliveryLine[]
  transferLines   TransferLine[]
  stockMoves      StockMove[]
  stockAdjustments StockAdjustment[]
}

model ReorderRule {
  id        String @id @default(cuid())
  productId String @unique
  minQty    Float  @default(0)
  maxQty    Float  @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ==================== STOCK ====================

model StockQuant {
  id         String @id @default(cuid())
  productId  String
  locationId String
  quantity   Float  @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

// ==================== RECEIPTS (Incoming) ====================

enum OperationStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELLED
}

model Receipt {
  id            String          @id @default(cuid())
  reference     String          @unique
  supplier      String?
  scheduleDate  DateTime
  responsibleId String
  status        OperationStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  responsible User          @relation(fields: [responsibleId], references: [id])
  lines       ReceiptLine[]
  stockMoves  StockMove[]
}

model ReceiptLine {
  id        String @id @default(cuid())
  receiptId String
  productId String
  quantity  Float

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ==================== DELIVERY ORDERS (Outgoing) ====================

model DeliveryOrder {
  id              String          @id @default(cuid())
  reference       String          @unique
  deliveryAddress String?
  scheduleDate    DateTime
  operationType   String          @default("delivery")
  responsibleId   String
  status          OperationStatus @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  responsible User            @relation(fields: [responsibleId], references: [id])
  lines       DeliveryLine[]
  stockMoves  StockMove[]
}

model DeliveryLine {
  id              String @id @default(cuid())
  deliveryOrderId String
  productId       String
  quantity        Float

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

// ==================== INTERNAL TRANSFERS ====================

model InternalTransfer {
  id             String          @id @default(cuid())
  reference      String          @unique
  fromLocationId String
  toLocationId   String
  responsibleId  String
  scheduleDate   DateTime
  status         OperationStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  fromLocation Location       @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   Location       @relation("TransferTo", fields: [toLocationId], references: [id])
  responsible  User           @relation(fields: [responsibleId], references: [id])
  lines        TransferLine[]
  stockMoves   StockMove[]
}

model TransferLine {
  id         String @id @default(cuid())
  transferId String
  productId  String
  quantity   Float

  transfer InternalTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product          @relation(fields: [productId], references: [id])
}

// ==================== STOCK ADJUSTMENTS ====================

model StockAdjustment {
  id             String          @id @default(cuid())
  reference      String          @unique
  productId      String
  locationId     String
  countedQty     Float
  systemQty      Float
  difference     Float
  responsibleId  String
  status         OperationStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  product     Product    @relation(fields: [productId], references: [id])
  location    Location   @relation(fields: [locationId], references: [id])
  responsible User       @relation(fields: [responsibleId], references: [id])
  stockMoves  StockMove[]
}

// ==================== STOCK MOVE (Ledger) ====================

enum MoveType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

model StockMove {
  id               String          @id @default(cuid())
  reference        String
  moveType         MoveType
  productId        String
  fromLocationId   String?
  toLocationId     String?
  quantity         Float
  status           OperationStatus @default(DONE)
  responsibleId    String
  createdAt        DateTime        @default(now())

  // Relations
  product          Product          @relation(fields: [productId], references: [id])
  fromLocation     Location?        @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation       Location?        @relation("ToLocation", fields: [toLocationId], references: [id])
  responsible      User             @relation(fields: [responsibleId], references: [id])

  // Polymorphic references to source documents
  receiptId        String?
  deliveryOrderId  String?
  transferId       String?
  adjustmentId     String?

  receipt          Receipt?          @relation(fields: [receiptId], references: [id])
  deliveryOrder    DeliveryOrder?    @relation(fields: [deliveryOrderId], references: [id])
  transfer         InternalTransfer? @relation(fields: [transferId], references: [id])
  adjustment       StockAdjustment?  @relation(fields: [adjustmentId], references: [id])

  @@index([productId])
  @@index([moveType])
  @@index([createdAt])
  @@index([reference])
}

// ==================== SEQUENCE COUNTER ====================

model Sequence {
  id      String @id @default(cuid())
  prefix  String @unique // e.g. "WH/IN", "WH/OUT", "WH/INT", "WH/ADJ"
  counter Int    @default(0)
}
