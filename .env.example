# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET="your-secret-here"
# Set to your production domain (required for OAuth callbacks and email links)
AUTH_URL="https://your-domain.vercel.app"

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Gmail address used to send verification/reset emails
EMAIL_FROM="noreply@gmail.com"
# Gmail App Password (create at https://myaccount.google.com/apppasswords)
EMAIL_PASSWORD=""

# ── Application base URL ─────────────────────────────────────────────────────
# Used inside email templates for verification/reset links
BASE_URL="https://your-domain.vercel.app"
